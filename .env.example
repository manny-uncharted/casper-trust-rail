# Casper testnet driver (scripts/run-testnet.ts) — copy to .env and fill in.
# Values below are the LIVE testnet deployment (see DEPLOYED.md).

# Node JSON-RPC endpoint. Public no-auth node used for the live deploy:
CASPER_NODE_URL=https://node.testnet.casper.network/rpc
CASPER_CHAIN_NAME=casper-test

# Path to the agent's ed25519 secret key (PEM). Fund this account from the faucet.
CASPER_SECRET_KEY_PEM=./contracts/keys/secret_key.pem

# Optional CSPR.cloud bearer token — only needed if you point CASPER_NODE_URL at
# a CSPR.cloud endpoint (https://node.testnet.cspr.cloud/rpc) instead.
CSPR_CLOUD_ACCESS_TOKEN=

# Deployed contract hashes — live on casper-test (see DEPLOYED.md).
TRUSTRAIL_IDENTITY_HASH=hash-50de6c7535ef4196db67904a7c5a6fa5a1d56199e6100edd8c7b042fdf0b03de
TRUSTRAIL_REPUTATION_HASH=hash-d66a18fa40dfc17e199bcbde6aff02ade40ffd4fd1b8adfe022c1ba5145427ba
TRUSTRAIL_ORACLE_HASH=hash-7a1316142309897f674c5be6c86ac3dfa21869c79aa59738716ac480fdee514b

# Agent identity + the beneficiary account screened before posting.
TRUSTRAIL_AGENT_ID=veridex-tbill-oracle
TRUSTRAIL_PAYTO=account-hash-b8335dca7ea75611d30562b4a07092a3dcc90c057626a6ffc4d9ed084a73c20c
