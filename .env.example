# Casper testnet driver (scripts/run-testnet.ts) — copy to .env and fill in.

# Node JSON-RPC endpoint (CSPR.cloud or your own node)
CASPER_NODE_URL=https://node.testnet.cspr.cloud/rpc
CASPER_CHAIN_NAME=casper-test

# Path to the agent's ed25519 secret key (PEM). Fund this account from the faucet.
CASPER_SECRET_KEY_PEM=./keys/secret_key.pem

# Optional CSPR.cloud bearer token (sponsored for buildathon teams)
CSPR_CLOUD_ACCESS_TOKEN=

# Deployed contract hashes (from `cargo odra build` + put-deploy)
TRUSTRAIL_IDENTITY_HASH=hash-...
TRUSTRAIL_REPUTATION_HASH=hash-...
TRUSTRAIL_ORACLE_HASH=hash-...

# Agent identity + the beneficiary account screened before posting
TRUSTRAIL_AGENT_ID=veridex-tbill-oracle
TRUSTRAIL_PAYTO=account-hash-...
